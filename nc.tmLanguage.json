{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "NC Language",
  "scopeName": "source.nc",
  "fileTypes": ["nc"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [{
        "name": "comment.line.nc",
        "match": "!#.*"
      }]
    },
    "keywords": {
      "patterns": [{
        "name": "keyword.control.nc",
        "match": "(!if!|!else!|!loop!|!while!|!ret!|!stop!|!skip!|!jun!|!ask!)"
      }, {
        "name": "keyword.other.nc",
        "match": "\\b(say|nClass)\\b"
      }, {
        "name": "keyword.operator.nc",
        "match": "!!"
      }]
    },
    "types": {
      "patterns": [{
        "name": "storage.type.nc",
        "match": "(!num!|!numD!|!numF!|!fra!|!sintax!|!func!)"
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.nc",
        "begin": "\"",
        "end": "\"",
        "patterns": [{
          "name": "constant.character.escape.nc",
          "match": "\\\\."
        }]
      }]
    },
    "numbers": {
      "patterns": [{
        "name": "constant.numeric.nc",
        "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
      }]
    },
    "booleans": {
      "patterns": [{
        "name": "constant.language.nc",
        "match": "(!A|!2|true|false)"
      }]
    },
    "operators": {
      "patterns": [{
        "name": "keyword.operator.comparison.nc",
        "match": "(==|!=|<=|>=|<|>)"
      }, {
        "name": "keyword.operator.arithmetic.nc",
        "match": "(\\+|-|\\*|\\/|%)"
      }, {
        "name": "keyword.operator.assignment.nc",
        "match": "="
      }, {
        "name": "keyword.operator.arrow.nc",
        "match": "->"
      }]
    },
    "functions": {
      "patterns": [{
        "name": "entity.name.function.nc",
        "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*nClass\\(\\)\\[)"
      }]
    },
    "variables": {
      "patterns": [{
        "name": "variable.other.nc",
        "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
      }]
    }
  }
}
